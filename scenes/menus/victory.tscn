[gd_scene load_steps=2 format=3]

[ext_resource type="Script" path="res://scenes/menus/victory.gd" id="1"]

; --- Nœud racine ---
[node name="Victory" type="Control"]
layout_mode = 3
anchors_preset = 15
anchor_right = 1.0
anchor_bottom = 1.0
script = ExtResource("1")

; --- CenterContainer : centre tout le contenu ---
[node name="CenterContainer" type="CenterContainer" parent="."]
layout_mode = 1
anchors_preset = 15
anchor_right = 1.0
anchor_bottom = 1.0
grow_horizontal = 2
grow_vertical = 2

; --- VBoxContainer : empile Victoire + Bouton verticalement ---
[node name="VBoxContainer" type="VBoxContainer" parent="CenterContainer"]
layout_mode = 2
custom_minimum_size = Vector2(220, 0)

; --- Label Victoire ---
[node name="Victoire" type="Label" parent="CenterContainer/VBoxContainer"]
layout_mode = 2
text = "Victoire !"
horizontal_alignment = 1

; --- Bouton Rejouer ---
[node name="BoutonRejouer" type="Button" parent="CenterContainer/VBoxContainer"]
layout_mode = 2
text = "Rejouer"
