[gd_scene load_steps=2 format=3]

[ext_resource type="Script" path="res://scenes/menus/pause.gd" id="1"]

; --- Nœud racine ---
[node name="PauseMenu" type="Control"]
layout_mode = 3
anchors_preset = 15
anchor_right = 1.0
anchor_bottom = 1.0
script = ExtResource("1")

; --- Fond semi-transparent ---
[node name="Background" type="ColorRect" parent="."]
layout_mode = 1
anchors_preset = 15
anchor_right = 1.0
anchor_bottom = 1.0
color = Color(0, 0, 0, 0.5)

; --- CenterContainer : centre tout le contenu ---
[node name="CenterContainer" type="CenterContainer" parent="."]
layout_mode = 1
anchors_preset = 15
anchor_right = 1.0
anchor_bottom = 1.0
grow_horizontal = 2
grow_vertical = 2

; --- VBoxContainer : empile Pause + Bouton verticalement ---
[node name="VBoxContainer" type="VBoxContainer" parent="CenterContainer"]
layout_mode = 2
custom_minimum_size = Vector2(220, 0)

; --- Label Pause ---
[node name="Pause" type="Label" parent="CenterContainer/VBoxContainer"]
layout_mode = 2
text = "PAUSE"
horizontal_alignment = 1

; --- Bouton Reprendre ---
[node name="BoutonReprendre" type="Button" parent="CenterContainer/VBoxContainer"]
layout_mode = 2
text = "Reprendre"
